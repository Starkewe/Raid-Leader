boss_display_name = "The Chainmaster"
max_health = 6500
movement_speed_range_units_per_second = 7.5
attack_range_units = 20.0
movement_stop_range_units = 5.0
combat_radius = 128.0
attack_damage = 10
attack_cooldown = 2.0
basic_attack_id = "linked_lash"
basic_attack_display_name = "Linked Lash"
basic_attack_damage_type = "physical"
basic_attack_secondary_target_count = 1
basic_attack_secondary_damage_multiplier = 1.5
basic_attack_secondary_closest_to_primary = true
basic_attack_raidwide_every_n_attacks = 3
basic_attack_raidwide_damage = 6
