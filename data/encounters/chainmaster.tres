[resource]
script = ExtResource("1_encounter")
encounter_id = "chainmaster"
display_name = "The Chainmaster"
description = "A sustained physical-AOE encounter built around chained basic attacks, every-third-attack raid damage, selective pulls, movement-breakable collars, and high-stress stampede transitions."
