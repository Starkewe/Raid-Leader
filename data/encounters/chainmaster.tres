basic_attack_raidwide_display_name = "Crack the Whip"
basic_attack_raidwide_damage_type = "physical"
basic_attack_raidwide_delay = 0.5
abilities = Array[ExtResource("2_ability_type")]([SubResource("Ability_BarbedRecall"), SubResource("Ability_WhirlingLinks"), SubResource("Ability_IronCollar")])
