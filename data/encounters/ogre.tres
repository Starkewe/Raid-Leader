[resource]
script = ExtResource("1_encounter")
encounter_id = "ogre"
display_name = "Ogre: The Earthgnasher"
description = "The first complete V1 encounter: tank-swap Slams, Twin Sweeping Pull, curable Grabbing Roar, outward Earthshaker Stomps, formation-scattering Boulder Tosses, persistent Cracked Ground, and a final Frenzy."
scene_path = "res://scenes/combat_scene.tscn"
boss_display_name = "The Earthgnasher"
max_health = 6000
movement_speed_range_units_per_second = 7.0
attack_range_units = 5.0
combat_radius = 128.0
attack_damage = 10
attack_cooldown = 2.0
basic_attack_id = "ogre_slam"
basic_attack_display_name = "Slam"
basic_attack_status_effect = SubResource("Status_SlamVulnerability")
abilities = Array[ExtResource("2_ability_type")]([SubResource("Ability_TwinSweepingPull"), SubResource("Ability_GrabbingRoar"), SubResource("Ability_EarthshakerStomp"), SubResource("Ability_BoulderToss"), SubResource("Ability_EmpoweredSlam")])
phases = Array[ExtResource("3_phase_type")]([SubResource("Phase_One"), SubResource("Phase_Two"), SubResource("Phase_Frenzy")])
initial_ability_delay = 6.0
debug_logging_enabled = true
show_debug_region_guides = true
show_debug_range_rings = true
debug_max_range_units = 50.0
